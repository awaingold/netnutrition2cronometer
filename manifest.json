{
    "manifest_version": 3,
    "name": "NetNutrition2Cronometer",
    "version": "1.0.1",
    "description": "An extension to directly import NetNutrition data into custom foods in Cronometer.",
    "icons": {
        "32": "./icons/icon32.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "js": ["scrapeNutrition.js"],
            "matches": ["*://nutrition.hfs.uw.edu/*"]
        },
        {
            "js": ["setInformation.js"],
            "matches": ["*://cronometer.com/*", "*://*.cronometer.com/*"],
            "run_at": "document_start"
        }
    ],
    "host_permissions": [
        "*://*.cronometer.com/*",
        "*://*.uw.edu/*"
    ],
    "permissions": ["tabs"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "./icons/icon32.png"
    }
}