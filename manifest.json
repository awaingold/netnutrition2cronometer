{
    "manifest_version": 3,
    "name": "NetNutrition2Cronometer",
    "version": "1.0.0",
    "description": "An extension to directly import NetNutrition data into custom foods in Cronometer.",
    "icons": {
        "32": "images/icon32.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
        "js": [
            "scrapeNutrition.js"
        ],
        "matches": [
            "*://*.uw.edu/*"
        ]
        },
        {
        "js": [
            "setNutrient.js"
        ],
        "matches": [
            "*://*.cronometer.com/*"
        ]
        }
    ],
    "host_permissions": [
        "*://*.cronometer.com/*",
        "*://*.uw.edu/*"
    ],
    "permissions": ["tabs"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon32.png"
    }
}